{
  "name": "@sopkit/color",
  "version": "1.0.0",
  "description": "Premium, lightweight color conversion utility for Hex, RGB, RGBA, and HSL colorspaces.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "sopkit",
    "color",
    "hex",
    "rgb",
    "rgba",
    "hsl",
    "convert",
    "conversion"
  ],
  "author": "SopKit",
  "license": "MIT",
  "homepage": "https://sopkit.github.io/color-converter/"
}
