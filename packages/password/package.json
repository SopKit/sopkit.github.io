{
  "name": "@sopkit/password",
  "version": "1.0.0",
  "description": "Premium, lightweight password generation and strength analysis library for browser and Node.js.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "sopkit",
    "password",
    "generator",
    "strength",
    "entropy",
    "security",
    "random-password"
  ],
  "author": "SopKit",
  "license": "MIT",
  "homepage": "https://sopkit.github.io/password-generator/"
}
