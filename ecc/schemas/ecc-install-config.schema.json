{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECC Install Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "target": {
      "type": "string",
      "enum": [
        "claude",
        "claude-project",
        "cursor",
        "antigravity",
        "codex",
        "gemini",
        "opencode",
        "codebuddy",
        "joycode",
        "qwen",
        "zed"
      ]
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(baseline|lang|framework|capability):[a-z0-9-]+$"
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(baseline|lang|framework|capability):[a-z0-9-]+$"
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
