{
  "version": "1.0.0",
  "enabled": true,
  "name": "quality-gate",
  "description": "Run a full quality gate check (build, type check, lint, tests). Trigger manually from the Agent Hooks panel.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/quality-gate.sh"
  }
}
