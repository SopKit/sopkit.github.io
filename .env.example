# ============================================
# 30tools Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# REQUIRED: Stack Auth (authentication)
# Get these from https://app.stack-auth.com -> Project Settings
# Without these, the app will still work but auth features will be disabled.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# OPTIONAL: Only needed for specific features
# ============================================

# API Keys (for AI-powered tools)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
RAPIDAPI_KEY=

# Google Cloud / Translation
GOOGLE_CLOUD_TRANSLATE_API_KEY=
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=

# SEO & Site Verifications
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Integration Keys
TELEGRAM_BOT_TOKEN=
MCP_AUTH_TOKEN=

# AdSense Configuration
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-1828915420581549
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
