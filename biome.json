{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "error"
			},
			"a11y": {
				"useButtonType": "warn",
				"useValidAnchor": "error",
				"useAltText": "error"
			},
			"style": {
				"useConst": "warn",
				"useTemplate": "warn"
			},
			"performance": {
				"noAccumulatingSpread": "warn"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	}
}
